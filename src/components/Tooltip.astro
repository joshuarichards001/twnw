---
interface Props {
  title: string;
}
const { title } = Astro.props;
---

<span class="tooltip-wrapper relative inline-block">
  <button
    type="button"
    class="tooltip-trigger underline decoration-dotted decoration-base-content/40 underline-offset-4 cursor-help bg-transparent p-0"
    aria-expanded="false"
  >
    <slot />
  </button>
  <span
    role="tooltip"
    class="tooltip-content hidden absolute left-1/2 -translate-x-1/2 top-full mt-2 z-50 bg-base-100 border border-base-300 rounded-lg shadow-lg px-3 py-2 text-sm font-normal normal-case tracking-normal w-64 max-w-[calc(100vw-2rem)] text-left text-base-content/90"
    >{title}</span
  >
</span>

<script>
  function closeAll() {
    document
      .querySelectorAll(".tooltip-content")
      .forEach((c) => c.classList.add("hidden"));
    document
      .querySelectorAll<HTMLButtonElement>(".tooltip-trigger")
      .forEach((t) => t.setAttribute("aria-expanded", "false"));
  }

  document.querySelectorAll<HTMLElement>(".tooltip-wrapper").forEach((wrap) => {
    const trigger = wrap.querySelector<HTMLButtonElement>(".tooltip-trigger");
    const content = wrap.querySelector<HTMLElement>(".tooltip-content");
    if (!trigger || !content) return;

    trigger.addEventListener("click", (e) => {
      e.stopPropagation();
      const willOpen = content.classList.contains("hidden");
      closeAll();
      if (willOpen) {
        content.classList.remove("hidden");
        trigger.setAttribute("aria-expanded", "true");
      }
    });
  });

  document.addEventListener("click", (e) => {
    const target = e.target as HTMLElement;
    if (!target.closest(".tooltip-wrapper")) closeAll();
  });

  document.addEventListener("keydown", (e) => {
    if (e.key === "Escape") closeAll();
  });
</script>
